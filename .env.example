DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_application_client_id_here

# Optional: set this to register slash commands to one guild instantly while developing.
# If omitted, commands are registered globally and may take up to about an hour to appear.
DISCORD_GUILD_ID=your_test_server_guild_id_here

# Optional: keep true/default so npm start syncs slash commands before login.
# Set to false only if commands are managed by a separate deploy step.
REGISTER_COMMANDS_ON_STARTUP=true

# Optional: NEIS Open API key. If omitted, NEIS sample-key behavior is used.
# Auto meal channels are configured per server with /자동급식 설정.
NEIS_API_KEY=your_neis_api_key_here

# Optional: SQLite file used for profiles/economy/moderation persistence.
BOT_SQLITE_PATH=data/profiles.sqlite

# Optional: legacy JSON file to import into an empty SQLite database on first run.
BOT_JSON_MIGRATION_PATH=data/profiles.json

# Optional: Lavalink v4 node used by the music system.
# npm start auto-downloads Lavalink.jar, application.yml, youtube-source plugin config,
# and yt-dlp into MUSIC_RUNTIME_DIR when MUSIC_AUTO_SETUP=true and LAVALINK_HOST is empty.
MUSIC_AUTO_SETUP=true
MUSIC_RUNTIME_DIR=data/music-runtime

# Optional: set LAVALINK_HOST only when using your own external Lavalink node.
LAVALINK_HOST=
LAVALINK_PORT=2333
LAVALINK_PASSWORD=youshallnotpass
LAVALINK_SECURE=false
LAVALINK_CLIENT_NAME=heeheebot/0.10
LAVALINK_AUTO_START=true
LAVALINK_JAR_PATH=
LAVALINK_JAR_URL=https://github.com/lavalink-devs/Lavalink/releases/latest/download/Lavalink.jar
LAVALINK_CONFIG_PATH=
LAVALINK_YOUTUBE_PLUGIN_VERSION=
LAVALINK_READY_TIMEOUT_MS=90000

# Optional: default search source prefix for Lavalink loadtracks (ytsearch, ytmsearch, scsearch).
MUSIC_SEARCH_PREFIX=ytsearch

# Optional: pin the controller panel message when the bot has permission.
MUSIC_PIN_PANEL=false

# Optional: use yt-dlp as a metadata/search fallback before handing URLs back to Lavalink.
YTDLP_ENABLED=true
YTDLP_AUTO_DOWNLOAD=true
YTDLP_PATH=yt-dlp
YTDLP_TIMEOUT_MS=12000
YTDLP_ASSET_URL=
