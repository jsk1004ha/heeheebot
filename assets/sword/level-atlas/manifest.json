  "kind": "sprite",
  "sheetPlan": "four 5x5 raw prop sheets, 25 unique sword icons per sheet",
  "background": "#FF00FF",
  "importantArtRule": "Every sword must have a unique silhouette, blade geometry, guard shape, grip, pommel, material language, and fantasy identity. Do not reuse the same sword with only stronger glow or color changes.",
  "batches": [
    {
      "id": "batch_01",
      "levels": "1-25",
      "prompt": "prompts/batch-01-levels-001-025.txt"
    },
    {
      "id": "batch_02",
      "levels": "26-50",
      "prompt": "prompts/batch-02-levels-026-050.txt"
    },
    {
      "id": "batch_03",
      "levels": "51-75",
      "prompt": "prompts/batch-03-levels-051-075.txt"
    },
    {
      "id": "batch_04",
      "levels": "76-100",
      "prompt": "prompts/batch-04-levels-076-100.txt"
    }
