  "outputs": {
    "rawSheets": "raw/batch-*/raw-sheet.png",
    "agentSpriteForgeProcessed": "processed/batch-*",
    "cleanExtractedIcons": "extracted/batch-*/sword_001.png through sword_100.png",
    "cleanBatchSheets": "extracted/batch-*/sheet-transparent.png",
    "cleanFullAtlas": "extracted/atlas-100-transparent.png",
